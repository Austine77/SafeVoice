PORT=5000
NODE_ENV=production

# MongoDB Atlas
# Replace PUT_YOUR_MONGODB_PASSWORD_HERE with your current MongoDB Atlas database-user password.
# If your password contains @, #, %, /, ?, &, or spaces, URL-encode it first.
MONGODB_URI=mongodb+srv://SafeVoiceWorldwide:PUT_YOUR_MONGODB_PASSWORD_HERE@cluster0.nzs7yju.mongodb.net/safevoice?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=PUT_YOUR_JWT_SECRET_HERE
AUTH_SECRET=PUT_YOUR_AUTH_SECRET_HERE

CLIENT_URL=https://safevoice.onrender.com
WORLDWIDE_URL=https://safevoice-worldwide.onrender.com
CORS_ORIGINS=https://safevoice.onrender.com,https://safevoice-worldwide.onrender.com,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_KEY=PUT_YOUR_AZURE_TRANSLATOR_KEY_HERE
AZURE_TRANSLATOR_REGION=global

COMMUNITY_RISK_FEATURE=true
INDIGENOUS_LANGUAGE_REPORTING=true
USE_FILE_DB=false
USER_AGENT=SafeVoiceWorldwide/1.0
